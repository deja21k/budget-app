{
  "name": "personal-finance-backend",
  "version": "1.0.0",
  "description": "Local-only personal finance backend with SQLite",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "seed": "ts-node src/utils/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:stress": "vitest run src/tests/destructive.stress.test.ts",
    "download-tessdata": "node scripts/download-tessdata.js",
    "postinstall": "npm run download-tessdata"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "canvas": "^3.2.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
